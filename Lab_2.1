using System;

namespace Lab2_1
{
    class Program
    {
        static void Main()
        {
            double a = 0, b = 1, h = 0.1;
            int n = (int)((b - a) / h);
            if (n % 2 != 0) n++; // Метод Сімпсона потребує парну кількість кроків

            double sum = Function(a) + Function(b);
            for (int i = 1; i < n; i++)
            {
                double x = a + i * h;
                sum += (i % 2 == 0) ? 2 * Function(x) : 4 * Function(x);
            }

            double result = (h / 3) * sum;
            Console.WriteLine($"Результат інтегрування: {result:F6}");
        }

        static double Function(double x) => 3.0 / (8.0 * x + 1.0); // Варіант 20
    }
}
