    class Program
    {
        static void Main()
        {
            BinaryTree tree = new BinaryTree();

            [cite_start]// Додавання студентів [cite: 144]
            tree.Insert(new Student("Yatsenko", 12345)); // Ключ - номер квитка [cite: 167]
            tree.Insert(new Student("Ivanov", 11111));
            tree.Insert(new Student("Petrov", 22222));

            Console.WriteLine("{0,-15} | {1,-10}", "Прізвище", "Квиток");
