using System;
using System.Numerics;

namespace Lab2_3
{
    class Program
    {
        static void Main()
        {
            int n = 12; // 15 - 3 = 12 студентів для розподілу
            BigInteger factorial = 1;

            for (int i = 1; i <= n; i++)
                factorial *= i;

            Console.WriteLine($"Тип вибірки: Перестановки без повторень");
            Console.WriteLine($"Кількість способів (12!): {factorial}");
        }
    }
}
