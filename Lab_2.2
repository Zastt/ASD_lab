using System;
using System.Text.RegularExpressions;

namespace Lab2_2
{
    class Program
    {
        static void Main()
        {
            // Шаблон: Починається з +, потім цифри, потім A-K або ^ або &
            string pattern = @"^\+[0-9]+([A-K]+|\^|\&)$";
            string[] testWords = { "+123ABC", "+555^", "123ABC", "+777" };

            foreach (var word in testWords)
            {
                bool isValid = Regex.IsMatch(word, pattern);
                Console.WriteLine($"Слово: {word,-10} | Валідне: {isValid}");
            }
        }
    }
}
